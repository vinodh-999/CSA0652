def generate_permutations(arr, restricted_pair):
    result = []

    def backtrack(path, remaining):
        if len(remaining) == 0:
            result.append(path[:])
            return

        for x in remaining:
            if path:
                last = path[-1]

                if ((last == restricted_pair[0] and x == restricted_pair[1]) or
                    (last == restricted_pair[1] and x == restricted_pair[0])):
                    continue

            new_remaining = remaining[:]
            new_remaining.remove(x)

            path.append(x)
            backtrack(path, new_remaining)
            path.pop()

    backtrack([], arr)

    return result

elements = ['A', 'B', 'C']
restricted_pair = ('A', 'B')

perms = generate_permutations(elements, restricted_pair)

for p in perms:
    print(p)
